{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "app",
  "name": "OTel JS Instrumentation Generator",
  "id": "nearform-otelinstrumentationgenerator-app",
  "info": {
    "keywords": ["opentelemetry", "otel", "instrumentation", "javascript", "nodejs", "observability", "tracing"],
    "description": "Generate OpenTelemetry Node.js instrumentation code with a dynamic configuration form. Select signals, instrumentations, exporters, and download ready-to-use code.",
    "author": {
      "name": "Near form"
    },
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "screenshots": [],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "includes": [
    {
      "type": "page",
      "name": "OTel JS Generator",
      "path": "/a/%PLUGIN_ID%/otel-generator",
      "addToNav": true,
      "defaultNav": true
    },
    {
      "type": "page",
      "icon": "book",
      "name": "Developer Guide",
      "path": "/a/%PLUGIN_ID%/developer-guide",
      "addToNav": true
    },
    {
      "type": "page",
      "icon": "cog",
      "name": "Configuration",
      "path": "/plugins/%PLUGIN_ID%",
      "role": "Admin",
      "addToNav": true
    }
  ],
  "dependencies": {
    "grafanaDependency": ">=12.3.0",
    "plugins": []
  }
}
